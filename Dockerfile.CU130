# ============================================================================
# OPENWAKEWORD TRAINER - CUDA 13 / BLACKWELL (sm_120 / sm_121)
# ============================================================================

FROM nvcr.io/nvidia/cuda:13.0.1-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# ---------------------------------------------------------------------------
# System dependencies
# ---------------------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    python3.10 python3.10-venv python3.10-dev python3-dev python3-pip \
    git git-lfs curl build-essential portaudio19-dev libsndfile1 \
    dos2unix \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3.10 /usr/bin/python3 \
    && ln -sf /usr/bin/python3.10 /usr/bin/python

WORKDIR /app

# ---------------------------------------------------------------------------
# Create isolated venv (CRITICAL FOR CUDA STACK STABILITY)
# ---------------------------------------------------------------------------
RUN python3 -m venv /app/.venv
ENV PATH="/app/.venv/bin:$PATH"

# ---------------------------------------------------------------------------
# Upgrade pip tooling inside venv
# ---------------------------------------------------------------------------
RUN pip install --no-cache-dir --upgrade pip setuptools wheel

# ---------------------------------------------------------------------------
# Install training requirements (NO torch here)
# ---------------------------------------------------------------------------
COPY requirements_130.txt .

#RUN pip install --no-cache-dir --no-deps -r requirements_130.txt || true
RUN pip install --no-cache-dir -r requirements_130.txt

# ---------------------------------------------------------------------------
# FORCE PyTorch CU130 (must override anything above)
# ---------------------------------------------------------------------------
RUN pip install --no-cache-dir \
    torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu130

# ---------------------------------------------------------------------------
# Verify CUDA PyTorch install
# ---------------------------------------------------------------------------
RUN python -c "import torch; print(torch.__version__); assert '+cu130' in torch.__version__"

# ---------------------------------------------------------------------------
# Install Lightning Utilities
# ---------------------------------------------------------------------------
RUN pip install --no-cache-dir lightning-utilities

# ---------------------------------------------------------------------------
# Clone and install OpenWakeWord
# ---------------------------------------------------------------------------
RUN git clone https://github.com/dscripka/openWakeWord openwakeword \
    && pip install --no-cache-dir -e ./openwakeword

# ---------------------------------------------------------------------------
# Patch: disable Piper dependency (we use Kokoro)
# ---------------------------------------------------------------------------
COPY patches/skip-piper-import.py /tmp/skip-piper-import.py
RUN python /tmp/skip-piper-import.py openwakeword/openwakeword/train.py

# ---------------------------------------------------------------------------
# Download embedding models
# ---------------------------------------------------------------------------
RUN mkdir -p openwakeword/openwakeword/resources/models \
    && curl -L -o openwakeword/openwakeword/resources/models/embedding_model.onnx \
        'https://github.com/dscripka/openWakeWord/releases/download/v0.5.1/embedding_model.onnx' \
    && curl -L -o openwakeword/openwakeword/resources/models/melspectrogram.onnx \
        'https://github.com/dscripka/openWakeWord/releases/download/v0.5.1/melspectrogram.onnx'

# ---------------------------------------------------------------------------
# Copy training scripts
# ---------------------------------------------------------------------------
COPY train.py .
COPY setup-data.sh .
RUN chmod +x setup-data.sh

# ---------------------------------------------------------------------------
# Blackwell GPU support (RTX 5090 / DGX Spark / sm_120 / sm_121)
# ---------------------------------------------------------------------------
ENV TORCH_CUDA_ARCH_LIST="12.0;12.1" \
    CUDA_VISIBLE_DEVICES=all \
    CUDA_MODULE_LOADING=LAZY

# ---------------------------------------------------------------------------
# Default entrypoint
# ---------------------------------------------------------------------------
CMD ["/bin/bash"]